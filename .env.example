# Application Configuration
APP_NAME=ollama-api
APP_TITLE=Ollama LLM Gateway
APP_DESCRIPTION=Generic LLM service using Ollama with observability
APP_VERSION=1.0.0

# API Configuration
DOCS_URL=/docs
REDOC_URL=/redoc
METRICS_ENDPOINT=/metrics

# CORS Configuration (use JSON array format)
# CORS_ORIGINS=["http://localhost:3000","https://app.example.com"]
# CORS_CREDENTIALS=true
# CORS_METHODS=["*"]
# CORS_HEADERS=["*"]

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_TIMEOUT=300.0  # Optional: timeout in seconds, or leave empty for no timeout
# Memory limit for the ollama container (~75% of total host RAM).
# Without this, ollama reads MemFree from the kernel and ignores reclaimable buff/cache.
OLLAMA_MEM_LIMIT=6g

# SEQ Logging Configuration
# Seq runs in a separate container (dev & pre-prod). Ingestion port: 5340.
# On Windows dev with Docker: use host.docker.internal to reach containers outside this compose stack.
# On Linux/pre-prod: use the Seq container IP or a shared Docker network alias.
SEQ_SERVER_URL=http://host.docker.internal:5340
SEQ_API_KEY=your-api-key-here
LOG_LEVEL=INFO
LOG_FALLBACK_TO_CONSOLE=true

# LLM Default Parameters
DEFAULT_MODEL=llama3.2:3b
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2000
MIN_TEMPERATURE=0.0
MAX_TEMPERATURE=2.0
MIN_TOKENS=1
MAX_TOKENS_LIMIT=4096
